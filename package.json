{
  "name": "br-documents",
  "version": "0.1.0",
  "description": "Validators, generators, and masks for Brazilian documents (CPF, CNPJ). Zero dependencies.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cpf": {
      "types": "./dist/cpf/index.d.ts",
      "import": "./dist/cpf/index.js"
    },
    "./cpf/validator": {
      "types": "./dist/cpf/validator.d.ts",
      "import": "./dist/cpf/validator.js"
    },
    "./cpf/masker": {
      "types": "./dist/cpf/masker.d.ts",
      "import": "./dist/cpf/masker.js"
    },
    "./cpf/generator": {
      "types": "./dist/cpf/generator.d.ts",
      "import": "./dist/cpf/generator.js"
    },
    "./cnpj": {
      "types": "./dist/cnpj/index.d.ts",
      "import": "./dist/cnpj/index.js"
    },
    "./cnpj/validator": {
      "types": "./dist/cnpj/validator.d.ts",
      "import": "./dist/cnpj/validator.js"
    },
    "./cnpj/masker": {
      "types": "./dist/cnpj/masker.d.ts",
      "import": "./dist/cnpj/masker.js"
    },
    "./cnpj/generator": {
      "types": "./dist/cnpj/generator.d.ts",
      "import": "./dist/cnpj/generator.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:package": "publint && attw --pack --profile esm-only",
    "verify": "pnpm format:check && pnpm typecheck && pnpm test && pnpm build && pnpm lint:package"
  },
  "keywords": [
    "brazil",
    "cpf",
    "cnpj",
    "validator",
    "mask",
    "generator",
    "documentos"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cicerotcv/br-documents.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.10.0",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "prettier": "^3.9.4",
    "publint": "^0.3.12",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
